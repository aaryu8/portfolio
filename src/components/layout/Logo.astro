---
import { Image } from "astro:assets"

import logoDark from "@/assets/logo/dark.svg"
import logoLight from "@/assets/logo/light.svg"

interface Props {
  size?: number
  class?: string
}

const { size = 24, class: className } = Astro.props
---

<Image
  width={size * 1.5}
  height={size}
  src={logoDark}
  loading="eager"
  alt="Aryan Kaushik - Logo"
  class:list={["block dark:hidden", className]}
/>

<Image
  width={size * 1.5}
  height={size}
  src={logoLight}
  loading="eager"
  alt="Aryan kaushik - Logo"
  class:list={["hidden dark:block", className]}
/>
