---
import type { Education } from "@/collections/education"
import { formatYear } from "@/utils/date"

interface Props {
  education: Education
}

const { education } = Astro.props

const formatEducationRange = (startDate: Date, endDate?: Date) => {
  if (!endDate) return `${formatYear(startDate)} — Present`
  return `${formatYear(startDate)} — ${formatYear(endDate)}`
}
---

<article class="flex items-start justify-between gap-4 border-t py-6 first:border-t-0 first:pt-0 last:pb-0">
  <div class="space-y-0.5">
    <h3 class="text-lg font-semibold tracking-tight">{education.data.degree}</h3>
    <p class="text-sm text-muted">{education.data.institution} · {education.data.location}</p>
  </div>
  <p class="shrink-0 text-sm text-muted italic">
    {formatEducationRange(education.data.startDate, education.data.endDate)}
  </p>
</article>
