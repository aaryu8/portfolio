---
import { SlashIcon } from "@lucide/astro"
import { render } from "astro:content"

import type { Project } from "@/collections/projects"

interface Props {
  project: Project
}

const { project } = Astro.props
const { Content } = await render(project)
---

<article class="flex flex-col gap-1.5 border-t py-6 first:border-t-0 first:pt-0 last:pb-0">
  <h3 class="text-xl font-semibold tracking-tight">{project.data.title}</h3>
  <div class="max-w-prose leading-relaxed text-pretty prose prose-sm dark:prose-invert">
    <Content />
  </div>
  {
    project.data.links.length > 0 && (
      <ul class="mt-3 flex items-center gap-x-3">
        {project.data.links.map((link) => (
          <>
            <SlashIcon size={8} class="first:hidden" />
            <li>
              <a href={link.href} target="_blank" rel="noopener">
                {link.label}
              </a>
            </li>
          </>
        ))}
      </ul>
    )
  }
</article>